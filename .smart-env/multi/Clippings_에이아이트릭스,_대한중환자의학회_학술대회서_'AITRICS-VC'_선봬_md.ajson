ine":36},{"title":"#바이탈케어","target":"https://www.hitnews.co.kr/news/articleList.html?sc_area=A&sc_word=%EB%B0%94%EC%9D%B4%ED%83%88%EC%BC%80%EC%96%B4","line":36},{"title":"#신속대응시스템","target":"https://www.hitnews.co.kr/news/articleList.html?sc_area=A&sc_word=%EC%8B%A0%EC%86%8D%EB%8C%80%EC%9D%91%EC%8B%9C%EC%8A%A4%ED%85%9C","line":36},{"title":"#심정지","target":"https://www.hitnews.co.kr/news/articleList.html?sc_area=A&sc_word=%EC%8B%AC%EC%A0%95%EC%A7%80","line":36},{"title":"#에이아이트릭스","target":"https://www.hitnews.co.kr/news/articleList.html?sc_area=A&sc_word=%EC%97%90%EC%9D%B4%EC%95%84%EC%9D%B4%ED%8A%B8%EB%A6%AD%EC%8A%A4","line":36},{"title":"#의료 AI","target":"https://www.hitnews.co.kr/news/articleList.html?sc_area=A&sc_word=%EC%9D%98%EB%A3%8C%20AI","line":36},{"title":"#의료기기","target":"https://www.hitnews.co.kr/news/articleList.html?sc_area=A&sc_word=%EC%9D%98%EB%A3%8C%EA%B8%B0%EA%B8%B0","line":36},{"title":"#전자의무기록","target":"https://www.hitnews.co.kr/news/articleList.html?sc_area=A&sc_word=%EC%A0%84%EC%9E%90%EC%9D%98%EB%AC%B4%EA%B8%B0%EB%A1%9D","line":36},{"title":"#패혈증","target":"https://www.hitnews.co.kr/news/articleList.html?sc_area=A&sc_word=%ED%8C%A8%ED%98%88%EC%A6%9D","line":36},{"title":"#학술대회","target":"https://www.hitnews.co.kr/news/articleList.html?sc_area=A&sc_word=%ED%95%99%EC%88%A0%EB%8C%80%ED%9A%8C","line":36},{"title":"#환자 상태 악화 예측","target":"https://www.hitnews.co.kr/news/articleList.html?sc_area=A&sc_word=%ED%99%98%EC%9E%90%20%EC%83%81%ED%83%9C%20%EC%95%85%ED%99%94%20%EC%98%88%EC%B8%A1","line":36},{"title":"#AI 솔루션","target":"https://www.hitnews.co.kr/news/articleList.html?sc_area=A&sc_word=AI%20%EC%86%94%EB%A3%A8%EC%85%98","line":36},{"title":"#AITRICS-VC","target":"https://www.hitnews.co.kr/news/articleList.html?sc_area=A&sc_word=AITRICS-VC","line":36},{"title":"#EMR","target":"https://www.hitnews.co.kr/news/articleList.html?sc_area=A&sc_word=EMR","line":36},{"title":"#RRS","target":"https://www.hitnews.co.kr/news/articleList.html?sc_area=A&sc_word=RRS","line":36},{"title":"hlbang@hitnews.co.kr","target":"mailto:hlbang@hitnews.co.kr","line":38},{"title":"다른기사 보기","target":"https://www.hitnews.co.kr/news/articleList.html?sc_area=I&sc_word=hlbang","line":40}],"metadata":{"title":"에이아이트릭스, 대한중환자의학회 학술대회서 'AITRICS-VC' 선봬","source":"https://www.hitnews.co.kr/news/articleView.html?idxno=63866","author":null,"published":"2025-04-23","created":"2026-04-10","description":"에이아이트릭스(대표 김광준)는 오는 24일~25일 양일간 코엑스마곡 컨벤션센터에서 개최되는 '제45회 대한중환자의학회 정기학술대회(KSCCM·ACCC 2025)'에서 환자 상태 악화 예측 인공지능(AI) 솔루션 'AITRICS-VC(바이탈케어)'를 선보인다고 밝혔다.에이아이트릭스에 따르면 AITRICS-VC는 △6가지 활력징후 △11가지 혈액검사 △의식 상태 △나이 등 총 19개의 전자의무기록(EMR) 데이터를 분석해 패혈증, 심정지 등의 발생 위험도를 예측하는 의료 솔루션이다.회사는 학회에서 실제 임상 현장에서 활용 중인 바이탈케","tags":["#clippings","#에이아이트릭스","#대한중환자의학회","#학술대회","#환자","#AI","#의료기기","#의료","#바이탈케어","#AITRICS-VC","#패혈증","#심정지","#신속대응시스템","#RRS","#전자의무기록","#EMR"]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"key":"Clippings/에이아이트릭스, 대한중환자의학회 학술대회서 'AITRICS-VC' 선봬.md"},
