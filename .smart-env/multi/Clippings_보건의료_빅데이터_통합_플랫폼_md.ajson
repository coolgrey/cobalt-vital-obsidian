rce":"https://hcdl.mohw.go.kr/","author":null,"published":null,"created":"2026-04-13","description":"공공 보건의료 데이터 활용을 통한 국민건강 향상을 비전으로, 보건의료 빅데이터와 분산연구 네트워크 사업을 통합하여 보건의료 질 향상 및 정책개선, 개방 등 그리고 보건의료 데이터의 안전하고 투명한 활용을 목표로 합니다.","tags":["#clippings"]},"task_lines":[],"tasks":{},"codeblock_ranges":[]},"smart_blocks:Clippings/보건의료 빅데이터 통합 플랫폼.md#---frontmatter---": {"path":null,"last_embed":{"hash":"1oycxy8","at":1776066496445},"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.06550426,-0.00223809,0.0426868,-0.05420556,0.03985598,-0.01377321,-0.01478963,0.0370494,0.01100369,-0.00808325,0.00744331,-0.05773358,0.03771732,0.05592578,0.00627262,-0.01274692,0.05289184,0.02034792,-0.01575892,-0.01452455,0.08574119,-0.03934611,0.03844665,-0.07202087,0.03210812,0.03000764,0.02173475,-0.04990446,-0.03683177,-0.16132496,0.01856085,0.03316966,0.09487583,0.02861456,-0.04249738,-0.00801348,-0.00003022,0.08672683,0.00963421,0.05781059,0.03078418,-0.0013073,-0.02412562,-0.04294307,-0.01471606,-0.02565256,-0.00249561,-0.05567901,-0.02724171,0.01392335,-0.05097821,-0.03510067,0.03367066,-0.01098837,0.01973403,-0.00928787,0.01743894,0.06336402,0.04142033,0.0054339,0.05134839,0.0111591,-0.20709531,0.08936668,-0.03022323,0.02302184,0.0124369,0.02699037,-0.01018094,0.0296178,-0.00838435,0.05763654,-0.00098316,0.04761836,-0.01510962,0.00017238,0.04024697,-0.04320455,-0.07116099,-0.05979523,-0.00169471,0.02129909,-0.01612015,-0.0608041,-0.03466512,0.009483,-0.00316043,-0.10946504,0.03275818,-0.03794295,-0.00457209,-0.03080786,0.05856793,0.01696082,-0.06671433,-0.00723538,0.02340068,-0.04111831,-0.03320886,0.13394859,-0.07834246,0.0462705,0.06611591,-0.06938057,0.07888581,-0.0424554,-0.03168416,-0.07204811,-0.05418357,0.04110232,-0.01766581,0.01213457,0.05178706,-0.02709257,0.01658712,-0.02420428,-0.00279186,0.00691897,0.03822903,-0.00170012,-0.01966855,0.04260386,0.01076312,-0.04092877,0.010264,0.00056517,0.03782408,0.02248358,0.10673994,0.02966816,0.05062987,0.01562583,-0.06978465,0.00496667,-0